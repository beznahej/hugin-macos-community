#, c-format
msgid ""
"No or only partial information about field of view was found in image file\n"
"%s\n"
"\n"
"Please enter the horizontal field of view (HFOV) or the focal length and "
"crop factor."
msgstr ""
"In der Bilddatei \n"
"%s\n"
