<?xml version="1.0" ?>
<resource xmlns="http://www.wxwidgets.org/wxxrc" version="2.5.3.0">
  <object class="wxFrame" name="toolbox_frame">
    <object class="wxBoxSizer">
      <orient>wxVERTICAL</orient>
      <object class="sizeritem">
        <object class="wxSplitterWindow" name="toolbox_splitter">
          <object class="wxPanel">
            <object class="wxBoxSizer">
              <orient>wxVERTICAL</orient>
              <object class="sizeritem">
                <object class="wxNotebook" name="toolbox_notebook"/>
                <option>1</option>
                <flag>wxEXPAND</flag>
              </object>
            </object>
          </object>
          <object class="wxPanel">
            <object class="wxBoxSizer">
              <orient>wxVERTICAL</orient>
              <object class="sizeritem">
                <object class="unknown" name="toolbox_logpanel"/>
                <option>1</option>
                <flag>wxEXPAND</flag>
              </object>
            </object>
          </object>
          <orientation>horizontal</orientation>
          <minsize>100</minsize>
          <gravity>1</gravity>
        </object>
        <option>1</option>
        <flag>wxEXPAND</flag>
      </object>
    </object>
    <style>wxDEFAULT_FRAME_STYLE</style>
  </object>
  <object class="wxPanel" name="enfuse_panel">
    <object class="wxBoxSizer">
      <orient>wxVERTICAL</orient>
      <object class="sizeritem">
        <object class="wxSplitterWindow" name="enfuse_splitter">
          <object class="wxPanel">
            <object class="wxBoxSizer">
              <orient>wxVERTICAL</orient>
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>Files:</label>
                </object>
              </object>
              <object class="sizeritem">
                <object class="wxListCtrl" name="enfuse_files">
                  <style>wxLC_REPORT</style>
                </object>
                <option>2</option>
                <flag>wxALL|wxEXPAND</flag>
                <border>3</border>
              </object>
              <object class="sizeritem">
                <object class="wxBoxSizer">
                  <object class="sizeritem">
                    <object class="wxButton" name="enfuse_add_file">
                      <label>Add</label>
                      <tooltip>Load image file</tooltip>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <object class="sizeritem">
                    <object class="wxButton" name="enfuse_remove_file">
                      <label>Remove</label>
                      <tooltip>Remove selected file(s)</tooltip>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <object class="sizeritem">
                    <object class="wxButton" name="enfuse_create_file">
                      <label>Create</label>
                      <tooltip>Create brighter or darker versions of the selected file</tooltip>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <orient>wxHORIZONTAL</orient>
                </object>
                <flag>wxALIGN_CENTRE_HORIZONTAL</flag>
              </object>
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>Enfuse settings:</label>
                </object>
              </object>
              <object class="sizeritem">
                <object class="unknown" name="enfuse_properties"/>
                <option>3</option>
                <flag>wxALL|wxEXPAND</flag>
                <border>3</border>
              </object>
              <object class="sizeritem">
                <object class="wxBoxSizer">
                  <object class="sizeritem">
                    <object class="wxButton" name="enfuse_load_setting">
                      <label>Load</label>
                      <tooltip>Load saved setting</tooltip>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <object class="sizeritem">
                    <object class="wxButton" name="enfuse_save_setting">
                      <label>Save</label>
                      <tooltip>Save current setting</tooltip>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <object class="sizeritem">
                    <object class="wxButton" name="enfuse_reset_setting">
                      <bitmap stock_id="wxART_UNDO"/>
                      <tooltip>Reset setting to default parameters</tooltip>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <orient>wxHORIZONTAL</orient>
                </object>
                <flag>wxALIGN_CENTRE_HORIZONTAL</flag>
              </object>
              <object class="sizeritem">
                <object class="wxBoxSizer">
                  <object class="sizeritem">
                    <object class="wxButton" name="enfuse_preview">
                      <label>Preview</label>
                      <tooltip>Generate preview image</tooltip>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <object class="sizeritem">
                    <object class="wxButton" name="enfuse_enfuse">
                      <label>Output</label>
                      <tooltip>Generate final output</tooltip>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <orient>wxHORIZONTAL</orient>
                </object>
                <flag>wxALIGN_CENTRE_HORIZONTAL</flag>
              </object>
            </object>
          </object>
          <object class="wxPanel">
            <object class="wxBoxSizer">
              <object class="sizeritem">
                <object class="wxBoxSizer">
                  <object class="sizeritem">
                    <object class="wxStaticText">
                      <label>Preview</label>
                    </object>
                    <flag>wxALIGN_CENTRE_VERTICAL</flag>
                  </object>
                  <object class="spacer">
                    <option>1</option>
                    <flag>wxEXPAND</flag>
                  </object>
                  <object class="sizeritem">
                    <object class="wxChoice" name="enfuse_choice_zoom">
                      <content>
                        <item>100%</item>
                        <item>fit to window</item>
                        <item>200%</item>
                        <item>150%</item>
                        <item>75%</item>
                        <item>50%</item>
                        <item>25%</item>
                      </content>
                      <selection>1</selection>
                    </object>
                    <flag>wxALL|wxALIGN_CENTRE_VERTICAL</flag>
                    <border>3</border>
                  </object>
                  <orient>wxHORIZONTAL</orient>
                </object>
                <flag>wxEXPAND</flag>
              </object>
              <object class="sizeritem">
                <object class="unknown" name="enfuse_preview_window"/>
                <option>1</option>
                <flag>wxEXPAND</flag>
              </object>
              <orient>wxVERTICAL</orient>
            </object>
          </object>
          <orientation>vertical</orientation>
          <sashpos>300</sashpos>
          <minsize>200</minsize>
        </object>
        <option>1</option>
        <flag>wxEXPAND</flag>
      </object>
    </object>
  </object>
  <object class="wxPanel" name="perspective_panel">
    <object class="wxBoxSizer">
      <orient>wxHORIZONTAL</orient>
      <object class="sizeritem">
        <object class="wxBoxSizer">
          <object class="sizeritem">
            <object class="wxButton" name="perspective_load">
              <label>Load image...</label>
            </object>
            <flag>wxALL|wxALIGN_CENTRE</flag>
            <border>3</border>
          </object>
          <object class="sizeritem">
            <object class="wxFlexGridSizer">
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>Focal length:</label>
                </object>
                <flag>wxEXPAND|wxALIGN_CENTRE_VERTICAL</flag>
              </object>
              <object class="sizeritem">
                <object class="wxTextCtrl" name="perspective_focallength"/>
                <flag>wxEXPAND</flag>
                <minsize>60,-1</minsize>
              </object>
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>mm</label>
                </object>
                <flag>wxEXPAND|wxALIGN_CENTRE_VERTICAL</flag>
              </object>
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>Focal length multiplier:</label>
                </object>
                <flag>wxEXPAND|wxALIGN_CENTRE_VERTICAL</flag>
              </object>
              <object class="sizeritem">
                <object class="wxTextCtrl" name="perspective_cropfactor"/>
                <flag>wxEXPAND</flag>
                <minsize>60,-1</minsize>
              </object>
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>x</label>
                </object>
                <flag>wxEXPAND|wxALIGN_CENTRE_VERTICAL</flag>
              </object>
              <cols>3</cols>
              <rows>2</rows>
              <vgap>3</vgap>
              <hgap>6</hgap>
            </object>
            <flag>wxALL|wxEXPAND</flag>
            <border>3</border>
          </object>
          <orient>wxVERTICAL</orient>
          <object class="sizeritem">
            <object class="wxFlexGridSizer">
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>Rotation:</label>
                </object>
                <flag>wxALIGN_CENTRE_VERTICAL</flag>
              </object>
              <object class="sizeritem">
                <object class="wxChoice" name="perspective_rotation">
                  <content>
                    <item>Automatic</item>
                    <item>Normal</item>
                    <item>Rotate 90 deg clockwise</item>
                    <item>Rotate 90 anti-clockwise</item>
                    <item>Rotate 180 deg</item>
                  </content>
                  <selection>0</selection>
                </object>
                <flag>wxALL|wxEXPAND</flag>
                <border>3</border>
              </object>
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>Mode:</label>
                </object>
                <flag>wxALIGN_CENTRE_VERTICAL</flag>
              </object>
              <object class="sizeritem">
                <object class="wxChoice" name="perspective_mode">
                  <content>
                    <item>Rectangle</item>
                    <item>Lines</item>
                  </content>
                  <selection>0</selection>
                </object>
                <flag>wxALL|wxEXPAND</flag>
                <border>3</border>
              </object>
              <object class="spacer"/>
              <object class="sizeritem">
                <object class="wxButton" name="perspective_find_lines">
                  <label>Find lines</label>
                  <enabled>0</enabled>
                  <hidden>1</hidden>
                </object>
                <flag>wxALL|wxEXPAND</flag>
                <border>3</border>
              </object>
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>Crop:</label>
                </object>
                <flag>wxALIGN_CENTRE_VERTICAL</flag>
              </object>
              <object class="sizeritem">
                <object class="wxChoice" name="perspective_crop">
                  <content>
                    <item>outside</item>
                    <item>inside</item>
                  </content>
                  <selection>0</selection>
                </object>
                <flag>wxALL|wxEXPAND</flag>
                <border>3</border>
              </object>
              <cols>2</cols>
              <rows>4</rows>
              <growablecols>1</growablecols>
            </object>
            <flag>wxALL|wxEXPAND</flag>
            <border>3</border>
          </object>
          <object class="sizeritem">
            <object class="wxBoxSizer">
              <object class="sizeritem">
                <object class="wxButton" name="perspective_output">
                  <label>Output</label>
                  <tooltip>Save corrected image</tooltip>
                </object>
                <option>1</option>
                <flag>wxEXPAND</flag>
              </object>
              <object class="sizeritem">
                <object class="wxButton" name="perspective_output_pto">
                  <label>Save pto</label>
                  <tooltip>Save pto project file for further tweaking in Hugin</tooltip>
                </object>
                <option>1</option>
                <flag>wxEXPAND</flag>
              </object>
              <orient>wxHORIZONTAL</orient>
            </object>
            <flag>wxALL|wxEXPAND</flag>
            <border>3</border>
          </object>
          <object class="sizeritem">
            <object class="wxColourPickerCtrl" name="perspective_color_picker"/>
            <flag>wxALL|wxEXPAND</flag>
            <border>3</border>
          </object>
          <object class="sizeritem">
            <object class="wxStaticText" name="perspective_help_text"/>
            <flag>wxALL|wxEXPAND</flag>
            <border>6</border>
          </object>
        </object>
        <flag>wxALL|wxEXPAND</flag>
        <border>6</border>
      </object>
      <object class="sizeritem">
        <object class="wxBoxSizer">
          <object class="sizeritem">
            <object class="wxBoxSizer">
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>Preview</label>
                </object>
                <flag>wxALIGN_CENTRE_VERTICAL</flag>
              </object>
              <object class="sizeritem">
                <object class="wxChoice" name="perspective_preview">
                  <content>
                    <item>Original</item>
                    <item>Corrected</item>
                  </content>
                  <selection>0</selection>
                </object>
                <flag>wxALL|wxALIGN_CENTRE_VERTICAL</flag>
                <border>3</border>
              </object>
              <object class="sizeritem">
                <object class="wxStaticText" name="perspective_filename"/>
                <option>1</option>
                <flag>wxALIGN_CENTRE_VERTICAL</flag>
              </object>
              <object class="sizeritem">
                <object class="wxChoice" name="perspective_choice_zoom">
                  <content>
                    <item>100%</item>
                    <item>fit to window</item>
                    <item>200%</item>
                    <item>150%</item>
                    <item>75%</item>
                    <item>50%</item>
                    <item>25%</item>
                  </content>
                  <selection>1</selection>
                </object>
                <flag>wxALL|wxALIGN_CENTRE_VERTICAL</flag>
                <border>3</border>
              </object>
              <orient>wxHORIZONTAL</orient>
            </object>
            <flag>wxEXPAND</flag>
          </object>
          <object class="sizeritem">
            <object class="unknown" name="perspective_preview_window"/>
            <option>1</option>
            <flag>wxEXPAND</flag>
          </object>
          <orient>wxVERTICAL</orient>
        </object>
        <option>1</option>
        <flag>wxEXPAND</flag>
      </object>
    </object>
  </object>
  <object class="wxPanel" name="stacker_panel">
    <object class="wxBoxSizer">
      <object class="sizeritem">
        <object class="wxSplitterWindow" name="stacker_splitter">
          <object class="wxPanel">
            <object class="wxBoxSizer">
              <orient>wxVERTICAL</orient>
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>Files:</label>
                </object>
              </object>
              <object class="sizeritem">
                <object class="wxListCtrl" name="stacker_files">
                  <style>wxLC_REPORT</style>
                </object>
                <option>1</option>
                <flag>wxALL|wxEXPAND</flag>
                <border>3</border>
              </object>
              <object class="sizeritem">
                <object class="wxBoxSizer">
                  <object class="sizeritem">
                    <object class="wxButton" name="stacker_add_file">
                      <label>Add</label>
                      <tooltip>Load image file</tooltip>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <object class="sizeritem">
                    <object class="wxButton" name="stacker_add_files_dir">
                      <label>Read directory</label>
                      <tooltip>Load image files from a directory</tooltip>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <object class="sizeritem">
                    <object class="wxButton" name="stacker_remove_file">
                      <label>Remove</label>
                      <tooltip>Remove selected file(s)</tooltip>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <orient>wxHORIZONTAL</orient>
                </object>
                <flag>wxALIGN_CENTRE_HORIZONTAL</flag>
              </object>
              <object class="sizeritem">
                <object class="wxStaticLine"/>
                <flag>wxTOP|wxBOTTOM|wxEXPAND</flag>
                <border>6</border>
              </object>
              <object class="sizeritem">
                <object class="wxFlexGridSizer">
                  <object class="sizeritem">
                    <object class="wxStaticText">
                      <label>Stacking mode:</label>
                    </object>
                    <flag>wxALIGN_CENTRE_VERTICAL</flag>
                  </object>
                  <object class="sizeritem">
                    <object class="wxChoice" name="stacker_mode_choice">
                      <content>
                        <item>Mean</item>
                        <item>Median</item>
                        <item>Winsor trimmed mean</item>
                        <item>Sigma clipped mean</item>
                        <item>Minimum</item>
                        <item>Maximum</item>
                      </content>
                      <selection>0</selection>
                    </object>
                    <flag>wxALL|wxEXPAND</flag>
                    <border>3</border>
                  </object>
                  <object class="sizeritem">
                    <object class="wxStaticText" name="stacker_winsor_trim_label">
                      <label>Winsor trim:</label>
                    </object>
                    <flag>wxALIGN_CENTRE_VERTICAL</flag>
                  </object>
                  <object class="sizeritem">
                    <object class="wxSpinCtrlDouble" name="stacker_winsor_trim_spinctrl">
                      <min>0.01</min>
                      <max>0.49</max>
                      <digits>2</digits>
                      <inc>0.05</inc>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <object class="sizeritem">
                    <object class="wxStaticText" name="stacker_sigma_label">
                      <label>Max sigma:</label>
                      <hidden>1</hidden>
                    </object>
                    <flag>wxALIGN_CENTRE_VERTICAL</flag>
                  </object>
                  <object class="sizeritem">
                    <object class="wxSpinCtrlDouble" name="stacker_sigma_spinctrl">
                      <min>0.1</min>
                      <max>10</max>
                      <digits>1</digits>
                      <inc>0.1</inc>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <object class="sizeritem">
                    <object class="wxStaticText" name="stacker_sigma_iterations_label">
                      <label>Maximum number of iterations:</label>
                    </object>
                    <flag>wxALIGN_CENTRE_VERTICAL</flag>
                  </object>
                  <object class="sizeritem">
                    <object class="wxSpinCtrl" name="stacker_sigma_iterations_spinctrl">
                      <min>1</min>
                      <max>20</max>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <cols>2</cols>
                  <growablecols>1</growablecols>
                </object>
                <flag>wxALL|wxEXPAND</flag>
                <border>3</border>
              </object>
              <object class="sizeritem">
                <object class="wxBoxSizer">
                  <object class="sizeritem">
                    <object class="wxButton" name="stacker_preview">
                      <label>Preview</label>
                      <tooltip>Generate preview image</tooltip>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <object class="sizeritem">
                    <object class="wxButton" name="stacker_output">
                      <label>Output</label>
                      <tooltip>Generate final stacked image</tooltip>
                    </object>
                    <flag>wxALL</flag>
                    <border>3</border>
                  </object>
                  <orient>wxHORIZONTAL</orient>
                </object>
                <flag>wxALIGN_CENTRE_HORIZONTAL</flag>
              </object>
            </object>
          </object>
          <object class="wxPanel">
            <object class="wxBoxSizer">
              <object class="sizeritem">
                <object class="wxBoxSizer">
                  <object class="sizeritem">
                    <object class="wxStaticText">
                      <label>Preview</label>
                    </object>
                    <flag>wxALIGN_CENTRE_VERTICAL</flag>
                  </object>
                  <object class="spacer">
                    <option>1</option>
                    <flag>wxEXPAND</flag>
                  </object>
                  <object class="sizeritem">
                    <object class="wxChoice" name="stacker_choice_zoom">
                      <content>
                        <item>100%</item>
                        <item>fit to window</item>
                        <item>200%</item>
                        <item>150%</item>
                        <item>75%</item>
                        <item>50%</item>
                        <item>25%</item>
                      </content>
                      <selection>1</selection>
                    </object>
                    <flag>wxALL|wxALIGN_CENTRE_VERTICAL</flag>
                    <border>3</border>
                  </object>
                </object>
                <flag>wxEXPAND</flag>
              </object>
              <object class="sizeritem">
                <object class="unknown" name="stacker_preview_window"/>
                <option>1</option>
                <flag>wxEXPAND</flag>
              </object>
              <orient>wxVERTICAL</orient>
            </object>
          </object>
          <orientation>vertical</orientation>
          <sashpos>300</sashpos>
          <minsize>200</minsize>
        </object>
        <option>1</option>
        <flag>wxEXPAND</flag>
      </object>
      <orient>wxHORIZONTAL</orient>
    
    </object>
  </object>
  <object class="wxMenuBar" name="toolbox_menubar">
    <object class="wxMenu">
      <label>&amp;File</label>
      <object class="wxMenuItem" name="toolbox_close">
        <label>&amp;Quit</label>
      </object>
    </object>
  </object>
  <object class="wxDialog" name="enfuse_create_file">
    <object class="wxBoxSizer">
      <orient>wxVERTICAL</orient>
      <object class="sizeritem">
        <object class="wxBoxSizer">
          <object class="sizeritem">
            <object class="wxBoxSizer">
              <object class="sizeritem">
                <object class="wxFlexGridSizer">
                  <object class="sizeritem">
                    <object class="wxStaticText">
                      <label>Exposure step width:</label>
                    </object>
                    <flag>wxALL|wxALIGN_CENTRE_VERTICAL</flag>
                    <border>3</border>
                  </object>
                  <object class="sizeritem">
                    <object class="wxChoice" name="create_bright_choice_step_width">
                      <content>
                        <item>2/3 EV</item>
                        <item>1 EV</item>
                        <item>1 1/3 EV</item>
                      </content>
                      <selection>1</selection>
                    </object>
                    <flag>wxALL|wxALIGN_CENTRE_VERTICAL</flag>
                    <border>3</border>
                  </object>
                  <object class="sizeritem">
                    <object class="wxStaticText">
                      <label>Number of exposure steps:</label>
                    </object>
                    <flag>wxALL|wxALIGN_CENTRE_VERTICAL</flag>
                    <border>3</border>
                  </object>
                  <object class="sizeritem">
                    <object class="wxChoice" name="create_bright_choice_levels">
                      <content>
                        <item translate="0">1</item>
                        <item translate="0">2</item>
                        <item translate="0">3</item>
                        <item translate="0">4</item>
                        <item translate="0">5</item>
                      </content>
                      <selection>2</selection>
                    </object>
                    <flag>wxALL|wxEXPAND|wxALIGN_CENTRE_VERTICAL</flag>
                    <border>3</border>
                  </object>
                  <cols>2</cols>
                  <rows>2</rows>
                  <growablecols>1</growablecols>
                </object>
              </object>
              <object class="sizeritem">
                <object class="wxStaticLine"/>
                <flag>wxTOP|wxBOTTOM|wxEXPAND</flag>
                <border>6</border>
              </object>
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>Select which brighter and darker variants should be created</label>
                </object>
                <flag>wxALL</flag>
                <border>3</border>
              </object>
              <object class="sizeritem">
                <object class="wxListCtrl" name="create_bright_listctrl">
                  <style>wxLC_REPORT|wxLC_NO_HEADER|wxLC_SINGLE_SEL</style>
                </object>
                <option>1</option>
                <flag>wxALL|wxEXPAND</flag>
                <border>6</border>
              </object>
              <orient>wxVERTICAL</orient>
            </object>
            <flag>wxALL|wxEXPAND</flag>
            <border>6</border>
          </object>
          <object class="sizeritem">
            <object class="wxBoxSizer">
              <object class="sizeritem">
                <object class="wxStaticBitmap" name="create_bright_preview"/>
                <option>1</option>
                <flag>wxALL|wxEXPAND</flag>
                <border>3</border>
                <minsize>300,200</minsize>
              </object>
              <orient>wxVERTICAL</orient>
            </object>
            <option>1</option>
            <flag>wxEXPAND</flag>
          </object>
          <orient>wxHORIZONTAL</orient>
        </object>
        <option>1</option>
        <flag>wxALL|wxEXPAND</flag>
        <border>6</border>
      </object>
      <object class="sizeritem">
        <object class="wxGauge" name="enfuse_create_file_progress">
          <hidden>1</hidden>
          <style>wxGA_HORIZONTAL</style>
        </object>
        <flag>wxALL|wxEXPAND</flag>
        <border>6</border>
      </object>
      <object class="sizeritem">
        <object class="wxStdDialogButtonSizer">
          <object class="button">
            <object class="wxButton" name="wxID_OK">
              <label>OK</label>
              <default>1</default>
            </object>
          </object>
          <object class="button">
            <object class="wxButton" name="wxID_CANCEL">
              <label>Cancel</label>
            </object>
          </object>
        </object>
        <flag>wxEXPAND|wxALL</flag>
        <border>5</border>
      </object>
    </object>
    <title>Create brighter and darker versions of image file</title>
    <style>wxDEFAULT_DIALOG_STYLE|wxCAPTION|wxSYSTEM_MENU|wxRESIZE_BORDER|wxTAB_TRAVERSAL</style>
  </object>
  <object class="wxDialog" name="select_dir_dialog">
    <object class="wxBoxSizer">
      <orient>wxVERTICAL</orient>
      <object class="sizeritem">
        <object class="wxStaticBoxSizer">
          <object class="sizeritem">
            <object class="wxFlexGridSizer">
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>Directory:</label>
                </object>
                <flag>wxALL|wxALIGN_CENTRE_VERTICAL</flag>
                <border>3</border>
              </object>
              <object class="sizeritem">
                <object class="wxDirPickerCtrl" name="select_dir_picker">
                  <style platform="msw|mac">wxDIRP_USE_TEXTCTRL|wxDIRP_DIR_MUST_EXIST</style>
                  <style platform="unix">wxDIRP_DIR_MUST_EXIST</style>
                </object>
                <option>1</option>
                <flag>wxEXPAND</flag>
              </object>
              <object class="spacer"/>
              <object class="sizeritem">
                <object class="wxCheckBox" name="select_dir_recursive">
                  <label>include sub-directories</label>
                </object>
              </object>
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>Filename:</label>
                </object>
                <flag>wxALL|wxALIGN_CENTRE_VERTICAL</flag>
                <border>3</border>
              </object>
              <object class="sizeritem">
                <object class="wxTextCtrl" name="select_dir_filename">
                  <value>*</value>
                </object>
                <option>1</option>
                <flag>wxEXPAND</flag>
              </object>
              <object class="sizeritem">
                <object class="wxStaticText">
                  <label>Filetype:</label>
                </object>
                <flag>wxALL|wxALIGN_CENTRE_VERTICAL</flag>
                <border>3</border>
              </object>
              <object class="sizeritem">
                <object class="wxChoice" name="select_dir_filetype"/>
                <option>1</option>
                <flag>wxEXPAND</flag>
              </object>
              <cols>2</cols>
              <rows>4</rows>
              <vgap>3</vgap>
              <hgap>3</hgap>
              <growablecols>1</growablecols>
            </object>
            <flag>wxEXPAND</flag>
          </object>
          <label>Select directory and which files should be searched</label>
          <orient>wxVERTICAL</orient>
        </object>
        <option>1</option>
        <flag>wxALL|wxEXPAND</flag>
        <border>6</border>
      </object>
      <object class="sizeritem">
        <object class="wxStdDialogButtonSizer">
          <object class="button">
            <object class="wxButton" name="wxID_OK">
              <label>OK</label>
              <default>1</default>
            </object>
          </object>
          <object class="button">
            <object class="wxButton" name="wxID_CANCEL">
              <label>Cancel</label>
            </object>
          </object>
        </object>
        <flag>wxEXPAND|wxALL</flag>
        <border>5</border>
      </object>
    </object>
    <title>Search images in directory</title>
    <style>wxDEFAULT_DIALOG_STYLE|wxCAPTION|wxSYSTEM_MENU|wxRESIZE_BORDER|wxCLOSE_BOX|wxTAB_TRAVERSAL</style>
  </object>
</resource>